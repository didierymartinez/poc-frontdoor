{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/api/{**remainder}"
        },
        "AuthorizationPolicy": "AuthenticatedUser"
      }
    },
    "Clusters": {
      "backend-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://mock-api:3000"
          }
        }
      }
    }
  }
}
